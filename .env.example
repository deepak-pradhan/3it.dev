# ===========================================
# 3IT.dev Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# SMTP Configuration
# ------------------
# Configure your mail server settings
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM="3IT.dev <noreply@yourdomain.com>"

# Admin Configuration
# -------------------
# Email address to receive admin notifications (demo requests, contact forms)
ADMIN_EMAIL=admin@yourdomain.com

# Password for accessing the admin panel at /admin
# Use a strong, unique password
ADMIN_PASSWORD=your-secure-admin-password

# Application Settings (optional)
# -------------------------------
# These are typically set in ecosystem.config.cjs for production
# NODE_ENV=production
# PORT=3000
# ORIGIN=https://3it.dev
